# Copy to .env.local for local dev, and set these same values
# in Vercel → Project → Settings → Environment Variables for production.

# The Cloudflare Tunnel hostname pointing at your Windows Server bridge
CONTROL_API_URL=https://cod-api.eureka-technologies.co.uk

# Must match SharedSecret in server/cod-bridge.ps1 exactly
BRIDGE_SHARED_SECRET=your-shared-secret-here

# The password you and your friends type in to reach the control panel
ACCESS_CODE=choose-a-passphrase-here
